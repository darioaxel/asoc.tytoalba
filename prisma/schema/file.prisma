// Actualizar File para soportar múltiples usos
model File {
  id        String   @id @default(uuid())
  name      String
  mime      String
  size      Int
  path      String   @unique
  checksum  String
  createdAt DateTime @default(now())

  // Relaciones inversas
  receiptFile     ReceiptFile?
  supplierPayment SupplierPayment?
  
  // Relaciones con posts
  postCoverImage  Post?       @relation("PostCoverImage") // Una imagen puede ser cover de un post
  postImages      PostImage[] // Una imagen puede estar en múltiples posts

  @@map("files")
}
