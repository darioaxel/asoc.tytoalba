
// MODELS -----------------------------------------------
model Address {
  id          String   @id @default(uuid())
  addressLine String
  floorDoor   String?
  postalCode  String
  locality    String
  province    String
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([postalCode, province])
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  emailPersonal       String?   @unique
  firstName           String?
  lastName            String?
  phone               String?
  dni                 String?   @unique
  birthDate           DateTime?
  picture             String?
  passwordHash        String?
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  failedLoginAttempts Int       @default(0)
  lastLoginAt         DateTime?
  provider            String    @default("local")
  providerId          String?
  role                Role      @default(USER)

  memberTypeId    String?
  memberType      MembershipType? @relation(fields: [memberTypeId], references: [id])

  address     Address?
  paymentData UserPaymentData?

  posts Post[]
  
  // Relaciones con Receipt (como socio)
  receipts     Receipt[] 
  
  // Relaciones con Receipt (como admin que desbloquea/valida)
  unlockedReceipts   Receipt[]  @relation("ReceiptUnlockedBy")
  validatedReceipts  Receipt[]  @relation("ReceiptValidatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, role])
  @@index([provider, providerId])
}

model MembershipType {
  id          String   @id @default(uuid())
  type        MemberType @unique
  name        String   // "Socio Normal", "Socio Juvenil"...
  monthlyFee  Decimal  @db.Decimal(10,2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  users User[]
  
  @@map("membership_types")
}