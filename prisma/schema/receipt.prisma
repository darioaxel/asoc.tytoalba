model Receipt {
  id               String        @id @default(uuid())
  number           String        // 2024-001-XXXX
  fiscalYear       Int
  type             ReceiptType   @default(MONTHLY_FEE)
  concept          String
  
  // Montos
  baseAmount       Decimal       @db.Decimal(10,2)
  returnCharge     Decimal       @db.Decimal(10,2) @default(0)
  totalAmount      Decimal       @db.Decimal(10,2)
  paidAmount       Decimal       @db.Decimal(10,2) @default(0)
  
  currency         String        @default("EUR") @db.Char(3)
  status           ReceiptStatus @default(PENDING)
  
  // Visibilidad
  isLocked         Boolean       @default(true)
  unlockedAt       DateTime?
  unlockedById     String?
  unlockedBy       User?         @relation("ReceiptUnlockedBy", fields: [unlockedById], references: [id])
  
  // Fechas
  issueDate        DateTime      @default(now())
  dueDate          DateTime
  paymentDate      DateTime?
  
  // Validación por ADMIN
  validatedAt      DateTime?
  validatedById    String?
  validatedBy      User?         @relation("ReceiptValidatedBy", fields: [validatedById], references: [id])
  
  // Rechazo/devolución
  returnedAt       DateTime?
  rejectionReason  String?
  
  // Soft delete
  deletedAt        DateTime?
  
  // Relaciones
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  
  payments         Payment[]
  receiptFiles     ReceiptFile[]  // ← CORREGIDO: receiptFiles, no files

  @@unique([number, fiscalYear])
  @@index([userId, status, dueDate])
  @@index([status, isLocked])
  @@index([isLocked, issueDate])
  @@map("receipts")
}

model ReceiptFile {
  id          String   @id @default(uuid())
  receiptId   String
  receipt     Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  
  fileId      String   @unique
  file        File     @relation(fields: [fileId], references: [id])
  
  // RELACIÓN INVERSA 1:1 con Payment
  payment     Payment?
  
  uploadedAt  DateTime @default(now())
  fileType    String

  @@map("receipt_files")
}