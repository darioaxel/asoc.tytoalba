model Supplier {
  id           String    @id @default(uuid())
  name         String
  businessName String?
  taxId        String    @unique
  email        String?
  phone        String?
  address      String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  invoices SupplierInvoice[]

  @@map("suppliers")
}

model SupplierInvoice {
  id           String         @id @default(uuid())
  number       String
  fiscalYear   Int
  supplierId   String
  type         InvoiceType
  concept      String
  totalAmount  Decimal        @db.Decimal(12,2)
  paidAmount   Decimal        @db.Decimal(12,2) @default(0)
  currency     String         @default("EUR") @db.Char(3)
  status       InvoiceStatus  @default(PENDING)
  invoiceDate  DateTime       @default(now())
  dueDate      DateTime
  paymentDate  DateTime?
  deletedAt    DateTime?
  supplier     Supplier       @relation(fields: [supplierId], references: [id])

  supplierPayments SupplierPayment[]

  @@unique([number, fiscalYear])
  @@index([supplierId, status, dueDate])
  @@map("supplier_invoices")
}

model SupplierPayment {
  id          String        @id @default(uuid())
  invoiceId   String
  invoice     SupplierInvoice @relation(fields: [invoiceId], references: [id])
  
  amount      Decimal       @db.Decimal(12,2)
  method      PaymentMethod
  paymentDate DateTime      @default(now())
  reference   String?
  
  fileId      String?       @unique
  file        File?         @relation(fields: [fileId], references: [id])
  
  @@index([invoiceId])
  @@map("supplier_payments")
}

model AccountingEntry {
  id          String               @id @default(uuid())
  fiscalYear  Int
  month       Int                  // 1-12
  entryType   AccountingEntryType
  category    AccountingCategory
  concept     String
  amount      Decimal              @db.Decimal(15,2)
  currency    String               @default("EUR") @db.Char(3)
  entryDate   DateTime             @default(now())
  reference   String?              // factura, recibo…
  userId      String?
  receiptId   String?
  invoiceId   String?
  deletedAt   DateTime?

  @@index([fiscalYear, month])
  @@index([category])
  @@map("accounting_entries")
}