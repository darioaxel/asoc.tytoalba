// ~/prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider  = "postgresql"
}

// ENUMS ------------------------------------------------
enum Role {
  USER
  ADMIN
  ROOT
}

enum PaymentMethod {
  TRANSFERENCIA
  CARGO_BANCARIO
}

// MODELS -----------------------------------------------
model Address {
  id          String   @id @default(uuid())
  addressLine String
  floorDoor   String?
  postalCode  String
  locality    String
  province    String
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([postalCode, province])
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  emailPersonal       String?   @unique
  firstName           String?
  lastName            String?
  phone               String?
  dni                 String?   @unique
  birthDate           DateTime?
  picture             String?
  passwordHash        String?
  isActive            Boolean   @default(true)
  deactivatedAt       DateTime?
  failedLoginAttempts Int       @default(0)
  lastLoginAt         DateTime?
  provider            String    @default("local")
  providerId          String?
  role                Role      @default(USER)

  address     Address?
  paymentData UserPaymentData?

  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, role])
  @@index([provider, providerId])
}

// Datos de pago del usuario
model UserPaymentData {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentMethod PaymentMethod

  // Solo obligatorio cuando el método es CARGO_BANCARIO
  iban String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Restricciones
  @@index([paymentMethod])
  @@index([iban]) // búsquedas rápidas por IBAN
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  excerpt     String    @db.Text
  content     String    @db.Text
  cover       String?   @db.VarChar(500)
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  tags Tag[]

  @@index([published, publishedAt])
  @@index([slug])
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)
  slug  String @unique @db.VarChar(50)
  posts Post[]

  @@index([slug])
}
