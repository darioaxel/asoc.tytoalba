// ~/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"  
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Dirección válida para España
model Address {
  id           String @id @default(uuid())
  
  // Línea principal: "Calle Número"
  addressLine  String
  
  // Piso, puerta, escalera: "3º B" o "Bajo Dcha"
  floorDoor    String?
  
  // Código postal (5 dígitos)
  postalCode   String
  
  // Municipio/Población
  locality     String
  
  // Provincia (ej: "Madrid", "Barcelona")
  province     String

  // Relación con User (uno a uno opcional)
  userId       String? @unique
  user         User?   @relation(fields: [userId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Índice para búsquedas por CP y provincia
  @@index([postalCode, province])
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  emailPersonal   String?  @unique
  firstName       String?
  lastName        String?
  fullName        String?
  phone           String?
  
  // Datos de identificación española
  dni             String?  @unique
  birthDate       DateTime?

  avatar         String?

  // Credenciales locales (renombrado para seguridad)
  passwordHash    String?  // null si solo usa OAuth

  // Bloqueo - baja
  isActive        Boolean  @default(true)
  deactivatedAt   DateTime?

  // Seguridad: intentos fallidos y último login
  failedLoginAttempts Int   @default(0)
  lastLoginAt         DateTime?

  // Origen del usuario
  provider        String   @default("local") // local | google
  providerId      String?  // sub de Google, etc.

  role            Role     @default(USER)
  
  // Relación con dirección
  address         Address?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Índices para búsquedas frecuentes
  @@index([isActive, role])
  @@index([provider, providerId])
}

enum Role {
  USER
  ADMIN
  ROOT
}